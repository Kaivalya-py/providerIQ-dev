{
  "name": "provideriq-inquantic",
  "installCommand": "pnpm install",
  "buildCommand": "pnpm turbo run build",
  "outputDirectory": "apps/dashboard/dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
